  "keyFeatures": [
    "Remote device control via SSH",
    "Video streaming management with MediaMTX",
    "Media gallery with file-based upload and hooks",
    "Automatic network failover for dual-connection devices",
    "Real-time WebSocket notifications",
    "Scheduled actions with cron-based automation",
    "SMS gateway integration",
    "JWT and API key authentication"
  ],
  "publicApiSurface": [
    "POST /api/run/:device/:action - Execute device actions",
    "GET /api/ping/:device - Check device connectivity",
    "GET /api/cpsi - Get CPSI sensor data",
    "GET /api/battery - Get battery telemetry",
    "GET /api/gps - Get GPS coordinates",
    "GET /api/imu - Get IMU sensor data",
    "POST /api/notifications/send - Send notifications",
    "GET /api/gallery/:device/events - List media events",
    "POST /api/gallery/:device/upload - Upload media files",
    "POST /api/gallery/:device/start - Start media service",
    "GET /api/hooks - List event hooks",
    "POST /api/hooks - Create event hook",
    "GET /api/watchers - Get file watcher status",
    "POST /api/slot/:deviceId/:slot - Switch device slot",
    "GET /api/health/:deviceId - Get slot health status"
  ]
